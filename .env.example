# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=postgresql://vinted:vinted@db:5432/vinted_bot

# Redis
REDIS_URL=redis://redis:6379/0

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Vinted session (encrypted cookie storage)
VINTED_SESSION_ENCRYPTION_KEY=change-me-to-32-byte-secret-key!!
VINTED_SESSION_FILE=/data/vinted_session.enc

# Gemini models
GEMINI_MODEL=gemini-2.5-flash
# Cheaper model used for the high-volume product-signature classification
GEMINI_SIGNATURE_MODEL=gemini-2.5-flash-lite

# Scheduler
SCAN_INTERVAL_MINUTES=15
NOTIFICATION_COOLDOWN_HOURS=24
# Min same-signature listings required before a price median is trusted
MIN_BENCHMARK_SAMPLES=3
# eBay benchmarking (legacy, needs Chromium / >=1GB RAM). Default off: the
# benchmark compares each listing to the median of its own product signature.
EBAY_BENCHMARK_ENABLED=false

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Development
DISABLE_SCHEDULER=false
