# Required
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=postgresql://vinted:vinted@db:5432/vinted_bot

# Redis
REDIS_URL=redis://redis:6379/0

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Vinted session (encrypted cookie storage)
VINTED_SESSION_ENCRYPTION_KEY=change-me-to-32-byte-secret-key!!
VINTED_SESSION_FILE=/data/vinted_session.enc

# Gemini model
GEMINI_MODEL=gemini-2.5-flash

# Scheduler
SCAN_INTERVAL_MINUTES=15
NOTIFICATION_COOLDOWN_HOURS=24
# Max listings per search sent to the AI matcher each scan (cheapest first)
MAX_AI_EVALUATIONS_PER_SEARCH=25

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Development
DISABLE_SCHEDULER=false
